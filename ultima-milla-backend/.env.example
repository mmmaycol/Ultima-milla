# ==========================================
# SERVIDOR
# ==========================================
PORT=3000
NODE_ENV=development

# ==========================================
# KAFKA - BROKER PRINCIPAL
# ==========================================
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ultima-milla-backend
KAFKA_GROUP_ID=ultima-milla-group

# ==========================================
# REDIS - TELEMETRÍA GPS Y CACHE
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==========================================
# POSTGRESQL - ESTADO ACTUAL (proyecciones)
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=ultima_milla

# ==========================================
# JWT
# ==========================================
JWT_SECRET=super-secret-key-cambiar-en-produccion
JWT_EXPIRATION=7d

# ==========================================
# PASARELA DE PAGO (Culqi / Stripe)
# ==========================================
CULQI_API_KEY=sk_test_xxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxx
PAYMENT_WEBHOOK_SECRET=whsec_xxxxxxxxxx
