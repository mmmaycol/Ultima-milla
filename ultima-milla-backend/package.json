{
  "name": "ultima-milla-backend",
  "version": "1.0.0",
  "description": "Sistema de Logística de Última Milla - Backend EDA con NestJS",
  "scripts": {
    "start": "node dist/main",
    "start:dev": "ts-node -r tsconfig-paths/register src/main.ts",
